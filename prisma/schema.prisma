// Prisma Schema for Hyva Transport MTMS
// Prisma 7: DB URLs go in prisma.config.ts, not here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN    // Platform Owner
  ORG_ADMIN      // Transporter Admin
  FIELD_MANAGER  // Site Supervisor
  OWNER          // Vehicle Owner (read-only access to own data)
}

enum ExpenseType {
  FUEL
  DRIVER_ADVANCE
  MAINTENANCE
  TOLL
  CASH_PAYMENT
}

model Transporter {
  id           String    @id @default(cuid())
  name         String
  registration String?   // GST/Business ID
  users        User[]
  projects     Project[]
  owners       Owner[]
  createdAt    DateTime  @default(now())
}

model User {
  id                 String       @id @default(cuid())
  email              String       @unique
  password           String
  role               Role         @default(ORG_ADMIN)
  mustChangePassword Boolean      @default(false)
  transporterId      String?
  transporter        Transporter? @relation(fields: [transporterId], references: [id])
  owner              Owner?
}

model Project {
  id            String      @id @default(cuid())
  projectName   String
  location      String
  transporterId String
  transporter   Transporter @relation(fields: [transporterId], references: [id])
  trips         Trip[]
  vehicles      Vehicle[]
}

model Owner {
  id              String      @id @default(cuid())
  ownerName       String
  phone           String
  defaultPassword String?     // Visible to admin until owner changes password
  transporterId   String
  transporter     Transporter @relation(fields: [transporterId], references: [id])
  userId          String?      @unique
  user            User?        @relation(fields: [userId], references: [id])
  vehicles        Vehicle[]
  settlements     Settlement[]
}

model Vehicle {
  id        String    @id @default(cuid())
  plateNo   String    @unique
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  trips     Trip[]
  expenses  Expense[]
}

model Trip {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  weight      Float    // MT (Metric Tons)
  ratePerTon  Float
  totalAmount Float    // weight * ratePerTon
}

model Expense {
  id        String      @id @default(cuid())
  date      DateTime    @default(now())
  vehicleId String
  vehicle   Vehicle     @relation(fields: [vehicleId], references: [id])
  amount    Float
  type      ExpenseType
  remarks   String?
}

enum SettlementStatus {
  PENDING
  SETTLED
}

model Settlement {
  id            String           @id @default(cuid())
  ownerId       String
  owner         Owner            @relation(fields: [ownerId], references: [id])
  periodStart   DateTime
  periodEnd     DateTime
  totalRevenue  Float
  totalFuel     Float            @default(0)
  totalAdvances Float            @default(0)
  totalMaint    Float            @default(0)
  totalTolls    Float            @default(0)
  totalOther    Float            @default(0)
  finalPayout   Float
  tripsCount    Int              @default(0)
  status        SettlementStatus @default(PENDING)
  settledAt     DateTime?
  createdAt     DateTime         @default(now())
}
