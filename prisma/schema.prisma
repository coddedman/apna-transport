// Prisma Schema for Hyva Transport MTMS
// Prisma 7: DB URLs go in prisma.config.ts, not here.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN    // Platform Owner
  ORG_ADMIN      // Transporter Admin
  FIELD_MANAGER  // Site Supervisor
}

enum ExpenseType {
  FUEL
  DRIVER_ADVANCE
  MAINTENANCE
  TOLL
  CASH_PAYMENT
}

model Transporter {
  id           String    @id @default(cuid())
  name         String
  registration String?   // GST/Business ID
  users        User[]
  projects     Project[]
  owners       Owner[]
  createdAt    DateTime  @default(now())
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  password      String
  role          Role         @default(ORG_ADMIN)
  transporterId String?
  transporter   Transporter? @relation(fields: [transporterId], references: [id])
}

model Project {
  id            String      @id @default(cuid())
  projectName   String
  location      String
  transporterId String
  transporter   Transporter @relation(fields: [transporterId], references: [id])
  trips         Trip[]
  vehicles      Vehicle[]
}

model Owner {
  id            String      @id @default(cuid())
  ownerName     String
  phone         String
  transporterId String
  transporter   Transporter @relation(fields: [transporterId], references: [id])
  vehicles      Vehicle[]
}

model Vehicle {
  id        String    @id @default(cuid())
  plateNo   String    @unique
  ownerId   String
  owner     Owner     @relation(fields: [ownerId], references: [id])
  projectId String?
  project   Project?  @relation(fields: [projectId], references: [id])
  trips     Trip[]
  expenses  Expense[]
}

model Trip {
  id          String   @id @default(cuid())
  date        DateTime @default(now())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
  projectId   String
  project     Project  @relation(fields: [projectId], references: [id])
  weight      Float    // MT (Metric Tons)
  ratePerTon  Float
  totalAmount Float    // weight * ratePerTon
}

model Expense {
  id        String      @id @default(cuid())
  date      DateTime    @default(now())
  vehicleId String
  vehicle   Vehicle     @relation(fields: [vehicleId], references: [id])
  amount    Float
  type      ExpenseType
  remarks   String?
}
